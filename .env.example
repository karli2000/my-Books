# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Supabase Postgres connection string (transaction pooler or direct)
# Example: postgres://postgres:password@db.<project>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Optional fallback used by db layer
DATABASE_URL=

# LLM Vision (OpenRouter via Vercel AI SDK)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cheap + strong default for multi-book extraction
BOOKS_VISION_MODEL=qwen/qwen2.5-vl-7b-instruct
